---
import Reveal from './Reveal.astro';
import type { SiteContent } from '../utils/i18n';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
---

<section id="testimonials" class="py-20 sm:py-28" aria-labelledby="testimonials-heading">
  <div class="section-container">
    <Reveal variant="up" class="mx-auto max-w-2xl text-center">
      <h2 id="testimonials-heading" class="section-heading">{content.testimonials.title}</h2>
    </Reveal>

    <ul class="mt-16 grid gap-8 md:grid-cols-3" role="list" data-reveal-stagger>
      {content.testimonials.items.map((item) => (
        <Reveal as="li" variant="slide" class="card flex flex-col">
          <blockquote class="flex-1">
            <svg class="mb-4 h-8 w-8 text-brand-accent/30" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
            </svg>
            <p class="text-brand-muted leading-relaxed">&ldquo;{item.quote}&rdquo;</p>
          </blockquote>
          <footer class="mt-6 border-t border-brand-border pt-4">
            <cite class="not-italic">
              <span class="font-semibold text-brand">{item.name}</span>
              <span class="block text-sm text-brand-muted">{item.role}, {item.company}</span>
            </cite>
          </footer>
        </Reveal>
      ))}
    </ul>
  </div>
</section>
