---
import Reveal from './Reveal.astro';
import type { SiteContent } from '../utils/i18n';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;

const featureIcons = [
  'M13 10V3L4 14h7v7l9-11h-7z',
  'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  'M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
];
---

<section id="features" class="bg-brand-surface py-20 sm:py-28" aria-labelledby="features-heading">
  <div class="section-container">
    <Reveal variant="up" class="mx-auto max-w-2xl text-center">
      <h2 id="features-heading" class="section-heading">{content.features.title}</h2>
      <p class="section-subheading mx-auto">{content.features.subtitle}</p>
    </Reveal>

    <ul class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list" data-reveal-stagger>
      {content.features.items.map((feature, i) => (
        <Reveal as="li" variant="scale" class="card group">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-white shadow-sm transition-colors group-hover:bg-brand-accent/10" aria-hidden="true">
            <svg class="h-6 w-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={featureIcons[i]} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-brand">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-brand-muted">{feature.description}</p>
        </Reveal>
      ))}
    </ul>
  </div>
</section>
