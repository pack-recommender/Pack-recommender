---
import Reveal from './Reveal.astro';
import type { SiteContent } from '../utils/i18n';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;

const stepIcons = [
  'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12',
  'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
];
---

<section id="how-it-works" class="py-20 sm:py-28" aria-labelledby="how-heading">
  <div class="section-container">
    <Reveal variant="up" class="mx-auto max-w-2xl text-center">
      <h2 id="how-heading" class="section-heading">{content.howItWorks.title}</h2>
      <p class="section-subheading mx-auto">{content.howItWorks.subtitle}</p>
    </Reveal>

    <ol class="mt-16 grid gap-8 md:grid-cols-3" role="list" data-reveal-stagger>
      {content.howItWorks.steps.map((step, i) => (
        <Reveal as="li" variant="up" class="card relative text-center md:text-start">
          <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-surface md:mx-0" aria-hidden="true">
            <svg class="h-7 w-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={stepIcons[i]} />
            </svg>
          </div>
          <span class="text-sm font-medium text-brand-accent">0{i + 1}</span>
          <h3 class="mt-2 text-xl font-bold text-brand">{step.title}</h3>
          <p class="mt-3 text-brand-muted">{step.description}</p>
          {i < content.howItWorks.steps.length - 1 && (
            <div class="absolute -end-4 top-1/2 hidden h-0.5 w-8 -translate-y-1/2 bg-brand-border md:block" aria-hidden="true"></div>
          )}
        </Reveal>
      ))}
    </ol>
  </div>
</section>
