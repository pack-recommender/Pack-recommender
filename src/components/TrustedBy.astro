---
import Reveal from './Reveal.astro';
import type { SiteContent } from '../utils/i18n';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;

const logos = [
  { name: 'NovaTech', initials: 'NT' },
  { name: 'EuroPack', initials: 'EP' },
  { name: 'Precision Co', initials: 'PC' },
  { name: 'GlobalMfg', initials: 'GM' },
  { name: 'FlexiPack', initials: 'FP' },
  { name: 'IndusCore', initials: 'IC' },
];
---

<section class="border-y border-brand-border bg-brand-surface py-12" aria-labelledby="trusted-heading">
  <div class="section-container">
    <Reveal variant="fade">
      <p id="trusted-heading" class="mb-8 text-center text-sm font-medium uppercase tracking-wider text-brand-muted">
        {content.trusted.title}
      </p>
      <ul class="flex flex-wrap items-center justify-center gap-8 sm:gap-12" role="list" aria-label="Partner companies" data-reveal-stagger>
        {logos.map((logo) => (
          <Reveal as="li" variant="fade">
            <div
              class="flex h-10 items-center gap-2 rounded-lg border border-brand-border bg-white px-4 text-sm font-semibold text-brand-muted transition-transform duration-300 hover:-translate-y-0.5"
              aria-label={logo.name}
            >
              <span class="flex h-6 w-6 items-center justify-center rounded bg-brand-surface text-xs font-bold text-brand">
                {logo.initials}
              </span>
              {logo.name}
            </div>
          </Reveal>
        ))}
      </ul>
    </Reveal>
  </div>
</section>
