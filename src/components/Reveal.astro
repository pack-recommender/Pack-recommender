---
interface Props {
  variant?: 'up' | 'fade' | 'scale' | 'slide';
  delay?: number;
  class?: string;
  as?: 'div' | 'section' | 'li' | 'article' | 'header';
}

const { variant = 'up', delay = 0, class: className = '', as: Tag = 'div' } = Astro.props;
---

<Tag
  class:list={['reveal', className]}
  data-reveal
  data-reveal-variant={variant}
  style={delay > 0 ? `--reveal-delay: ${delay}ms` : undefined}
>
  <slot />
</Tag>
